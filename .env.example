# ============================================================
#  BHOJAN - Environment Variables
#  Copy this file and rename it to: .env
#  Then fill in your values below
# ============================================================

# ---- MONGODB CONNECTION ----
# Option 1: Local MongoDB (if installed on your computer)
#   MONGO_URI=mongodb://localhost:27017/bhojan
#
# Option 2: MongoDB Atlas (FREE cloud database - RECOMMENDED)
#   Step 1: Go to https://www.mongodb.com/cloud/atlas/register
#   Step 2: Create a FREE cluster
#   Step 3: Click "Connect" → "Drivers" → Copy the connection string
#   Step 4: Replace <password> with your actual password
#   Step 5: Paste it below
#
MONGO_URI=mongodb://localhost:27017/bhojan

# ---- JWT SECRET ----
# Any random long string. Used to sign authentication tokens.
# You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=bhojan_super_secret_key_change_this_in_production_2024

# ---- SERVER PORT ----
PORT=5000

# ---- NODE ENVIRONMENT ----
NODE_ENV=development
